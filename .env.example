# Config for `docker compose up` (backend + database only).
# Copy to .env and fill in real values before deploying:
#   cp .env.example .env

# Postgres (used by both the db and server containers)
POSTGRES_USER=buddyscript
POSTGRES_PASSWORD=change_me
POSTGRES_DB=buddyscript

# The origin your frontend is served from — CORS is locked to this.
CLIENT_ORIGIN=https://your-frontend-domain.example

# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Optional overrides (defaults shown)
# ACCESS_TOKEN_TTL=15m
# REFRESH_TOKEN_TTL=7d
# MAX_UPLOAD_BYTES=5242880
# SERVER_PORT=4000
