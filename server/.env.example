# Postgres — point this at any local or hosted Postgres instance.
# Local (Homebrew/native) default:
DATABASE_URL="postgresql://buddyscript:buddyscript@localhost:5432/buddyscript?schema=public"

# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Auth — generate strong random values in production
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=5242880
